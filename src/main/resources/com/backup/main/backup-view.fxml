<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.backup.main.BackupController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <ButtonBar nodeOrientation="RIGHT_TO_LEFT" prefHeight="40.0" prefWidth="200.0">
        <buttons>
          <Button mnemonicParsing="false" text="Compare" onAction="#onCompareButtonClick" />
        </buttons>
         <padding>
            <Insets bottom="20.0" />
         </padding>
      </ButtonBar>
      <SplitPane dividerPositions="0.4696969696969697" prefHeight="704.0" prefWidth="816.0">
        <items>
            <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="213.0" prefWidth="328.0">
               <VBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" prefHeight="200.0" prefWidth="100.0">
                  <children>
                      <Label text="Source Files">
                        <padding>
                           <Insets bottom="10.0" left="20.0" top="10.0" />
                        </padding>
                     </Label>
                      <TableView fx:id="sourceFiles" minWidth="0" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="pathColumn" prefWidth="350.0" text="Path" />
                            <TableColumn fx:id="sizeColumn" prefWidth="100.0" text="Size" />
                           <TableColumn fx:id="dateColumn" prefWidth="160.0" text="Change Date" />
                        </columns>
                      </TableView>
                  </children>
               </VBox>
            </AnchorPane>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
               <VBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <Label graphicTextGap="100.0" text="Backup Files">
                     <padding>
                        <Insets bottom="10.0" left="20.0" top="10.0" />
                     </padding>
                  </Label>
                  <TableView minWidth="0" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn prefWidth="75.0" text="Path" />
                      <TableColumn prefWidth="75.0" text="Size" />
                        <TableColumn prefWidth="97.0" text="Changed Date" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            </AnchorPane>
        </items>
      </SplitPane>
   </children>
</VBox>
